PORT=4000
DATABASE_PATH=./data/document-audits.sqlite
CLIENT_ORIGIN=http://localhost:5173
APP_BASE_URL=http://localhost:5173
AUTH_SECRET=change-this-for-production

# Docker HTTPS reverse proxy
# For production, set both URLs to the public HTTPS URL, e.g. https://docs.company.net
# CLIENT_ORIGIN=https://localhost
# APP_BASE_URL=https://localhost

# Internal SMTP mail server
MAIL_HOST=mail.xxx.net
MAIL_PORT=25
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM="DocAudit <docaudit@xxx.net>"
MAIL_SECURE=false
MAIL_IGNORE_TLS=false
MAIL_REQUIRE_TLS=false
MAIL_TLS_REJECT_UNAUTHORIZED=true
MAIL_TLS_SERVERNAME=mail.xxx.net
MAIL_TLS_CA_FILE=
MAIL_CONNECTION_TIMEOUT_MS=10000
MAIL_DRY_RUN=false
NOTIFICATIONS_ENABLED=true
NOTIFICATION_CHECK_INTERVAL_MINUTES=60
